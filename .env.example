# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=docstore
POSTGRES_USER=docstore
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_URL=postgresql+asyncpg://docstore:changeme@postgres:5432/docstore

# ─────────────────────────────────────────────────────────────────────────────
# MinIO Object Storage
# ─────────────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_RAW=documents-raw
MINIO_BUCKET_PROCESSED=documents-processed
MINIO_SECURE=false

# ─────────────────────────────────────────────────────────────────────────────
# Apache Kafka
# ─────────────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_DOCUMENT_UPLOADED=document_uploaded
KAFKA_TOPIC_TEXT_EXTRACTED=text_extracted
KAFKA_TOPIC_DOCUMENT_CHUNKED=document_chunked
KAFKA_TOPIC_EMBEDDINGS_GENERATED=embeddings_generated
KAFKA_TOPIC_SUMMARY_GENERATED=summary_generated
KAFKA_TOPIC_DLQ=dlq.document_errors
KAFKA_CONSUMER_GROUP_TEXT_EXTRACTION=text-extraction-workers
KAFKA_CONSUMER_GROUP_CHUNKING=chunking-workers
KAFKA_CONSUMER_GROUP_EMBEDDING=embedding-workers
KAFKA_CONSUMER_GROUP_SUMMARIZATION=summarization-workers

# ─────────────────────────────────────────────────────────────────────────────
# Ollama (Local LLM)
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TEMPERATURE=0.1
OLLAMA_NUM_CTX=4096

# ─────────────────────────────────────────────────────────────────────────────
# Authentication (JWT)
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production-use-256-bit-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────────────────────────────────────
# API Gateway
# ─────────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost:80
MAX_UPLOAD_SIZE_MB=100

# ─────────────────────────────────────────────────────────────────────────────
# RAG Service (internal only)
# ─────────────────────────────────────────────────────────────────────────────
RAG_SERVICE_URL=http://rag_service:8001
RAG_TOP_K_RETRIEVE=20
RAG_TOP_K_RERANK=5
RAG_CONTEXT_TOKEN_BUDGET=3000

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Vite build-time)
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost/api
VITE_WS_URL=ws://localhost/ws
